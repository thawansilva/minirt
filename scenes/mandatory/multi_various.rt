# Mesmo objeto repetido: 2 cilindros, 2 esferas e 1 plano

A 0.3 255,255,255

C 0,4,-14 0,-0.2,1 65

L -8,10,-3 0.8 255,255,255

# Esfera vermelha
sp -4,0,8 2.0 255,60,60

# Esfera azul
sp 4,0,8 2.0 60,60,255

# Cilindro amarelo (vertical)
