A 0.15 255,255,255

C 0,5,-18 0,-0.1,1 60

L -10,20,-5 0.9 255,255,255
L 15,15,0 0.5 200,200,255

# Esfera brilhante (ks alto, shininess alto = highlight pequeno e intenso)
sp -6,0,12 5.0 255,50,50 0.9 0.7 0.2 128 0.0 255,255,255 1.0 0.0 none

# Esfera fosca (ks baixo = quase sem brilho)
sp 6,0,12 5.0 50,50,255 0.1 0.7 0.2 8 0.0 255,255,255 1.0 0.0 none

# Esfera com defaults (sem extras)
sp 0,7,16 3.0 50,255,50

# Chao (sem reflexao para manter foco no especular)
pl 0,-3,0 0,1,0 180,180,180 0.3 0.7 0.2 16 0.0 80,80,80 2.0 0.0 none

# Cilindro brilhante
cy 0,-3,8 0,1,0 2.0 6.0 255,200,0 0.7 0.6 0.2 64 0.0 200,150,0 2.0 0.0 none
